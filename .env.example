# ===========================================
# TEVI AUTOPILOT — Environment Variables
# ===========================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to git — .env is already in .gitignore
# ===========================================

# ===========================================
# VPS SERVER (server.js)
# ===========================================
PORT=3004

# Path to Chromium executable on VPS
# Find with: find /home -name 'chrome-headless-shell' 2>/dev/null
CHROMIUM_PATH=/home/vps-devata/.cache/ms-playwright/chromium_headless_shell-1228/chrome-headless-shell-linux64/chrome-headless-shell

# Upload directory on VPS
UPLOAD_DIR=/home/vps-devata/tevi-uploads
ARCHIVE_DIR=/home/vps-devata/tevi-uploads/archive

# Log level: debug | info | warn | error
LOG_LEVEL=info

# ===========================================
# N8N Environment Variables
# Set these in N8N → Settings → Variables
# ===========================================

# VPS upload directory (for SFTP nodes)
VPS_UPLOAD_DIR=/home/vps-devata/tevi-uploads

# VPS archive directory
VPS_ARCHIVE_DIR=/home/vps-devata/tevi-uploads/archive

# VPS upload URL (where server.js is running)
# For local VPS: http://13.75.2.24:3004
# For Cloudflare tunnel: https://your-tunnel-url.trycloudflare.com
VPS_UPLOAD_URL=http://13.75.2.24:3004

# Lock file path (for concurrency protection)
VPS_LOCK_FILE=/home/vps-devata/tevi-uploads/.tevi-upload.lock

# Email address for notifications
NOTIFY_EMAIL=your@email.com

# ===========================================
# N8N Credentials (setup in N8N UI, NOT here)
# ===========================================
# These are stored securely in N8N Credentials, not in .env

# Google Drive OAuth2:
#   N8N → Credentials → Google Drive OAuth2 API
#   - OAuth Client ID
#   - OAuth Client Secret
#   - OAuth Redirect URI: YOUR_N8N_URL/rest/oauth2-credential/callback

# SSH/SFTP (VPS):
#   N8N → Credentials → SSH
#   - Host: 13.75.2.24
#   - Port: 22
#   - Username: vps-devata
#   - Password: YOUR_VPS_PASSWORD

# SMTP Email:
#   N8N → Credentials → Email (SMTP)
#   - Host: smtp.your-email-provider.com
#   - Port: 587
#   - User: your@email.com
#   - Password: YOUR_EMAIL_PASSWORD

# TEVI Account (Custom credentials):
#   N8N → Credentials → Create New → Custom
#   - email: your-tevi@email.com
#   - password: your_tevi_password
#   - channelSlug: your_channel_name

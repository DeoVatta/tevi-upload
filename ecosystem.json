{
  "apps": [
    {
      "name": "tevi-upload",
      "script": "server.js",
      "cwd": "REPLACE_WITH_YOUR_PATH",
      "instances": 1,
      "exec_mode": "fork",
      "autorestart": true,
      "max_restarts": 10,
      "min_uptime": "10s",
      "exp_backoff_restart_delay": 1000,
      "watch": false,
      "kill_timeout": 60000,
      "env": {
        "NODE_ENV": "production",
        "PORT": "3004",
        "LOG_FILE": "REPLACE_WITH_YOUR_PATH/logs/tevi-upload.log"
      }
    }
  ]
}
